datatypes xsd = "http://www.w3.org/2001/XMLSchema-datatypes"

start = TEI.2 
TEI.2 = element TEI.2{new_text}
new_text = element text {body, lang}
lang = attribute lang {"en"} 
body = element body{div1} 
div1 = element div1 {milestone, p*, type, n, org, sample}
milestone = element milestone {empty, ed?, unit, n?}
n = attribute n {text} 
ed = attribute ed {text} 
unit = attribute unit {text}
p = element p {mixed{(milestone, term*, placeName)}} 
type = attribute type {text}
term = element term {text, lang}
org = attribute org {text}
sample = attribute sample {text}
placeName = element placeName 
